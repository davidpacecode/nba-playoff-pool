<p style="color: green"><%= notice %></p>

<% content_for :title, "Teams" %>

<h1>Teams</h1>

<div id="teams">
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Abbreviation</th>
        <th>Conference</th>
        <th>Logo</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @teams.each do |team| %>
        <tr>
          <td><%= team.name %></td>
          <td><%= team.abbreviation %></td>
          <td><%= team.conference.titleize %></td>
          <td><%= image_tag team.logo, width: 25, height: 25 if team.logo.attached? %></td>
          <td><%= link_to "View", team %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= link_to "New team", new_team_path %>

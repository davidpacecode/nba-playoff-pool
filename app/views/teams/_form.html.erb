<%= form_with(model: team) do |form| %>
  <% if team.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(team.errors.count, "error") %> prohibited this team from being saved:</h2>

      <ul>
        <% team.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :abbreviation, style: "display: block" %>
    <%= form.text_field :abbreviation %>
  </div>

  <div>
    <%= form.label :conference, style: "display: block" %>
    <%= form.select :conference, Team.conferences.keys.map { |c| [c.capitalize, c] } %>  </div>
  <div>
    <%= form.label :seed, style: "display: block" %>
    <%= form.number_field :seed %>
  </div>

  <div>
    <%= form.label :logo, style: "display: block" %>
    <%= form.file_field :logo %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>

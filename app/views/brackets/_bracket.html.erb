<div id="<%= dom_id bracket %>">
  <div class="wa-heading-xl">
    <strong>Name:</strong>
    <%= bracket.name %>
  </div>

  <div class="wa-heading-xl">
    <strong>Season:</strong>
    <%= bracket.season %>
  </div>

  <div class="wa-grid bracket-container wa-gap-0 wa-body-l wa-font-weight-bold">

    <%# top title row %>
    <div class="wa-span-grid"><span class="wa-heading-2xl"><%= bracket.name %></span></div>
    
    <%# header row %>
    <div>East R1</div>
    <div>East R2</div>
    <div>East Conf Finals</div>
    <div>NBA Finals</div>
    <div>West Conf Finals</div>
    <div>West R2</div>
    <div>West R1</div>
 
    <%# first row %>
    <wa-card>
      <%= turbo_frame_tag dom_id(first_round_series[ :eastern_0 ]) do %>
        <%= render "bracket_series", series: first_round_series[ :eastern_0 ] %>
      <% end %>
    </wa-card>
    <div></div>
    <div></div>
    <div></div>
    <div></div>
    <div></div>

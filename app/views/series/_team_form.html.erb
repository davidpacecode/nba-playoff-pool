<%= turbo_frame_tag dom_id(series) do %>
  <%= form_with(model: series, url: update_teams_series_path) do |form| %>
    <% if series.errors.any? %>
      <div style="color: red">
        <h2><%= pluralize(series.errors.count, "error") %> prohibited this series from being saved:</h2>

        <ul>
          <% series.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :top_seed_id, style: "display: block" %>
      <%= form.collection_select :top_seed_id, Team.all, :id, :name %>
    </div>

    <div>
      <%= form.label :bottom_seed_id, style: "display: block" %>
      <%= form.collection_select :bottom_seed_id, Team.all, :id, :name %>
    </div>

    <div>
      <%= form.submit %>
    </div>
  <% end %>
<% end %>
